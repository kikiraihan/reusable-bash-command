# setup AI provider untuk gfbpr
# Groq  → daftar gratis di https://console.groq.com
# Gemini → daftar gratis di https://aistudio.google.com/apikey
export GROQ_API_KEY="***"
export GEMINI_API_KEY="***"

# command untuk buat branch baru dari master, langsung push, dan set upstream
# Fungsi GFB (Git Feature Branch) dengan opsi push
# contoh penggunaan:
# gfb master fitur-keren
# gfb -p master fitur-keren
# gfb -p develop fitur-keren
gfb() {
  local push_to_origin=false
  local base_branch=""
  local branch_name=""

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -p|--push) push_to_origin=true ;;
      *)
        if [ -z "$base_branch" ]; then
          base_branch="$1"
        elif [ -z "$branch_name" ]; then
          branch_name="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi input
  if [ -z "$base_branch" ] || [ -z "$branch_name" ]; then
    echo "❌ Gunakan: gfb [-p] <base-branch> <nama-branch-baru>"
    echo "Contoh:"
    echo "  gfb master fitur-login"
    echo "  gfb develop fitur-payment"
    echo "  gfb -p develop fitur-api"
    return 1
  fi

  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch"

  if [ $? -ne 0 ]; then
    echo "⚠️ Gagal update $base_branch. Cek apakah ada uncommitted changes."
    return 1
  fi

  echo "🌿 Membuat branch: $branch_name dari $base_branch"
  git checkout -b "$branch_name"

  if [ "$push_to_origin" = true ]; then
    echo "🚀 Push dan set upstream..."
    git push -u origin "$branch_name"
    echo "✅ Berhasil dibuat dan di-push!"
  else
    echo "📍 Branch dibuat secara lokal."
    echo "Gunakan: git push -u origin $branch_name"
  fi
}

# Git Feature Branch Cleaner
# Menghapus branch yang sudah merged ke base branch
# Aman: ignore branch penting + bisa pilih branch
#
# contoh:
# gfbclean master
#
# contoh dengan filter:
# gfbclean master -f kiki
#
# contoh input pilihan:
# 1 3 5
# 1,3,5
# all
#
# output:
# 🗑 Branch yang bisa dihapus:
# [1] feature/login
# [2] feature/payment
# [3] bugfix/token
# Pilih nomor branch (contoh: 1 3 atau 1,3) atau ketik 'all' untuk semua:
gfbclean() {
  local base_branch=""
  local filter=""

  # parse arg
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        base_branch="$1"
        ;;
    esac
    shift
  done

  if [ -z "$base_branch" ]; then
    echo "❌ Gunakan: gfbclean <base-branch> [-f keyword]"
    return 1
  fi

  local original_branch=$(git rev-parse --abbrev-ref HEAD)

  # Tangkap Ctrl+C: balik ke branch semula sebelum exit
  trap "echo ''; echo '🔙 Kembali ke branch: $original_branch'; git checkout \"$original_branch\"; trap - INT; return 1" INT

  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch" || { trap - INT; return 1; }

  echo "🔍 Mencari branch yang sudah merged ke $base_branch..."
  local branches
  branches=$(git branch --merged "$base_branch" \
    | sed 's/^[* ]*//' \
    | grep -vE '^(master|main|develop|staging|production)$')

  if [ -n "$filter" ]; then
    branches=$(echo "$branches" | grep "$filter")
  fi

  if [ -z "$branches" ]; then
    echo "✅ Tidak ada branch yang cocok untuk dibersihkan."
    trap - INT
    return 0
  fi

  echo ""
  echo "🗑 Branch yang bisa dihapus:"
  local i=1
  declare -a branch_list
  while read -r branch; do
    echo "[$i] $branch"
    branch_list[$i]="$branch"
    ((i++))
  done <<< "$branches"

  echo ""
  read "selection?Pilih nomor branch (contoh: 1,3 atau 1,3,5) atau ketik 'all' untuk semua: "

  # ubah koma jadi spasi lalu split ke array (zsh-safe)
  local selection_clean=$(echo "$selection" | tr ',' ' ')
  local -a nums
  read -A nums <<< "$selection_clean"

  local -a selected_branches
  if [[ "$selection" == "all" ]]; then
    selected_branches=("${branch_list[@]}")
  else
    for num in "${nums[@]}"; do
      [[ "$num" =~ ^[0-9]+$ ]] && selected_branches+=("${branch_list[$num]}")
    done
  fi

  echo ""
  echo "Branch yang akan dihapus:"
  for b in "${selected_branches[@]}"; do
    [ -z "$b" ] && continue
    echo "- $b"
  done

  echo ""
  read "confirm?Lanjutkan hapus branch di atas? (y/N): "
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "❌ Dibatalkan."
    trap - INT
    return 0
  fi

  for branch in "${selected_branches[@]}"; do
    [ -z "$branch" ] && continue
    echo "➡️ Hapus local: $branch"
    git branch -d "$branch"
    echo "➡️ Hapus origin: $branch"
    git push origin --delete "$branch"
  done

  echo "✅ Selesai membersihkan branch."
  echo ""
  echo "🔙 Kembali ke branch: $original_branch"
  git checkout "$original_branch"
  trap - INT  # reset trap setelah selesai normal
}

# Git Feature Branch Checker
# Menampilkan branch yang BELUM merged ke base branch
# Aman: ignore branch penting
#
# contoh:
# gfbcheck master
#
# contoh dengan filter:
# gfbcheck master -f kiki
#
# output:
# 🌿 Branch yang belum merged ke master:
# [1] feature/login
# [2] feature/payment
# [3] bugfix/token
gfbcheck() {
  local base_branch=""
  local filter=""

  # parse arg
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        base_branch="$1"
        ;;
    esac
    shift
  done

  if [ -z "$base_branch" ]; then
    echo "❌ Gunakan: gfbcheck <base-branch> [-f keyword]"
    return 1
  fi

  local original_branch=$(git rev-parse --abbrev-ref HEAD)

  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch" || return 1

  echo "🔍 Mencari branch yang belum merged ke $base_branch..."
  local branches
  branches=$(git branch --no-merged "$base_branch" \
    | sed 's/^[* ]*//' \
    | grep -vE '^(master|main|develop|staging|production)$')

  if [ -n "$filter" ]; then
    branches=$(echo "$branches" | grep "$filter")
  fi

  if [ -z "$branches" ]; then
    echo "✅ Semua branch sudah merged ke $base_branch."
    return 0
  fi

  echo ""
  echo "🌿 Branch yang belum merged ke $base_branch:"
  local i=1
  while read -r branch; do
    echo "[$i] $branch"
    ((i++))
  done <<< "$branches"

  echo ""
  echo "Total: $((i-1)) branch"
  echo ""
  echo "🔙 Kembali ke branch: $original_branch"
  git checkout "$original_branch"
}

# gfblog master                        → compare master vs current branch
# gfblog master feature/login          → compare master vs feature/login
gfblog() {
  local base_branch="${1:-master}"
  local target_branch="${2:-$(git rev-parse --abbrev-ref HEAD)}"

  if [ "$target_branch" = "$base_branch" ]; then
    echo "⚠️  Target branch sama dengan base branch ($base_branch)."
    return 1
  fi

  local commits=$(git log "$base_branch".."$target_branch" --oneline --no-decorate)

  if [ -z "$commits" ]; then
    echo "✅ Tidak ada commit baru dibanding $base_branch."
    return 0
  fi

  echo ""
  echo "🌿 Target branch : $target_branch"
  echo "📌 Base branch   : $base_branch"
  echo ""
  echo "📋 Commit yang belum ada di $base_branch:"
  echo "$commits" | while read -r line; do
    echo "  - $line"
  done
  echo ""
  echo "Total: $(echo "$commits" | wc -l | tr -d ' ') commit"
}

# Git Feature Branch Find Commit
# Mencari commit hash ada di branch mana saja
# Opsional: -r untuk cek remote branches juga
#
# contoh:
# gfbfind 56c97cde945a078ee1525a20acc9ea0927c5580b
# gfbfind 56c97cde -r
# gfbfind 56c97cde -f feature
gfbfind() {
  local commit_hash=""
  local include_remote=false
  local filter=""

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -r|--remote) include_remote=true ;;
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        if [ -z "$commit_hash" ]; then
          commit_hash="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi input
  if [ -z "$commit_hash" ]; then
    echo "❌ Gunakan: gfbfind <commit-hash> [-r] [-f keyword]"
    echo "Contoh:"
    echo "  gfbfind 56c97cde"
    echo "  gfbfind 56c97cde945a078ee1525a20acc9ea0927c5580b -r"
    echo "  gfbfind 56c97cde -f feature"
    return 1
  fi

  # Validasi commit hash exist
  if ! git cat-file -e "$commit_hash^{commit}" 2>/dev/null; then
    echo "❌ Commit '$commit_hash' tidak ditemukan di repo ini."
    return 1
  fi

  local short_hash=$(git rev-parse --short "$commit_hash")
  local commit_msg=$(git log -1 --pretty=format:"%s" "$commit_hash")

  echo ""
  echo "🔍 Mencari commit: $short_hash"
  echo "📝 Pesan        : $commit_msg"
  echo ""

  # Tentukan flag: local saja atau termasuk remote
  local branch_flag=""
  if [ "$include_remote" = true ]; then
    echo "🌐 Mode: local + remote branches"
    branch_flag="-a"  # all: local + remote
  else
    echo "💻 Mode: local branches saja (gunakan -r untuk remote)"
    branch_flag=""    # default: local only
  fi
  echo ""

  # Cari branch yang mengandung commit ini
  local found_branches
  found_branches=$(git branch $branch_flag --contains "$commit_hash" \
    | sed 's/^[* ]*//' \
    | sed 's|^remotes/||')  # rapikan prefix remotes/

  if [ -n "$filter" ]; then
    found_branches=$(echo "$found_branches" | grep "$filter")
  fi

  if [ -z "$found_branches" ]; then
    echo "⚠️  Commit tidak ditemukan di branch manapun."
    return 0
  fi

  local count=$(echo "$found_branches" | wc -l | tr -d ' ')

  echo "✅ Ditemukan di $count branch:"
  echo ""
  local i=1
  while read -r branch; do
    [ -z "$branch" ] && continue
    echo "  [$i] $branch"
    ((i++))
  done <<< "$found_branches"
  echo ""
}

# Git Feature Branch List
# Menampilkan list branch yang mengandung keyword tertentu
# Opsional: -r untuk include remote branches juga
#
# contoh:
# gfbls kiki
# gfbls kiki -r
gfbls() {
  local keyword=""
  local include_remote=false

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -r|--remote) include_remote=true ;;
      *)
        if [ -z "$keyword" ]; then
          keyword="$1"
        fi
        ;;
    esac
    shift
  done

  # Jika tidak ada keyword, tampil semua branch
  # keyword kosong = grep akan match semua baris

  # Ambil local branches
  local local_branches
  local_branches=$(git branch \
    | sed 's/^[* ]*//' \
    | grep "$keyword")

  # Ambil remote branches (selalu, untuk keperluan cek & mode -r)
  local remote_branches
  remote_branches=$(git branch -r \
    | sed 's/^[* ]*//' \
    | sed 's/^origin\///' \
    | grep -v 'HEAD' \
    | grep "$keyword")

  # Tentukan sumber data sesuai mode
  local all_branches
  if [ "$include_remote" = true ]; then
    all_branches=$(printf "%s\n%s\n" "$local_branches" "$remote_branches" \
      | grep -v '^$' | sort -u)
  else
    all_branches="$local_branches"
  fi

  if [ -z "$all_branches" ]; then
    echo "⚠️  Tidak ada branch yang mengandung keyword: '$keyword'"
    return 0
  fi

  local keyword_label="${keyword:-semua}"
  local count=$(echo "$all_branches" | grep -c .)
  local mode="local"
  [ "$include_remote" = true ] && mode="local + remote"

  echo ""
  echo "🔍 Keyword  : $keyword_label"
  echo "🌐 Mode     : $mode"
  echo "📋 Ditemukan: $count branch"
  echo ""

  # Fetch dulu supaya info remote fresh
  echo "🔄 Fetching origin..."
  git fetch --quiet 2>/dev/null

  local i=1
  while read -r branch; do
    [ -z "$branch" ] && continue
    local has_local=false
    local has_remote=false
    echo "$local_branches"  | grep -qx "$branch" && has_local=true
    echo "$remote_branches" | grep -qx "$branch" && has_remote=true

    if $has_local && $has_remote; then
      # Hitung ahead/behind
      local ahead=$(git rev-list --count "origin/$branch".."$branch" 2>/dev/null)
      local behind=$(git rev-list --count "$branch".."origin/$branch" 2>/dev/null)
      local sync_info=""
      [ "$ahead" -gt 0 ] 2>/dev/null  && sync_info+=" ↑${ahead}"
      [ "$behind" -gt 0 ] 2>/dev/null && sync_info+=" ↓${behind}"
      [ -z "$sync_info" ] && sync_info=" ✓"
      echo "  [$i] $branch$sync_info"
      echo "       └─ origin/$branch"
    elif $has_local; then
      echo "  [$i] $branch  (local only — belum pernah push)"
    else
      echo "  [$i] origin/$branch  (remote only — belum di-fetch lokal)"
    fi
    ((i++))
  done <<< "$all_branches"
  echo ""
  echo "  ↑ = commit lokal belum di-push   ↓ = commit remote belum di-pull   ✓ = sinkron"
  echo ""
}

# Git Feature Branch PR Generator
# Generate PR title & description dari commit log menggunakan Groq atau Gemini
# Requires: GROQ_API_KEY atau GEMINI_API_KEY di environment
#
# contoh:
# gfbpr master                              → groq, current branch vs master
# gfbpr master kiki/feat/SP-829            → groq, branch spesifik
# gfbpr master -p gemini                   → pakai Gemini
# gfbpr master -p groq -m llama3-8b-8192   → groq, pilih model manual
# gfbpr master -p gemini -m gemini-1.5-pro → gemini, pilih model manual
#
# Model Groq gratis:
# llama-3.3-70b-versatile  → default, kualitas terbaik
# llama3-8b-8192           → lebih cepat, ringan
# gemma2-9b-it             → Google Gemma
# qwen-qwq-32b             → Qwen reasoning
# mistral-saba-24b         → Mistral
#
# Model Gemini gratis:
# gemini-2.0-flash         → default, cepat & gratis 1500 req/hari
# gemini-1.5-pro           → lebih powerful
gfbpr() {
  local base_branch="master"
  local target_branch=$(git rev-parse --abbrev-ref HEAD)
  local provider="groq"  # default provider
  local model=""         # kosong = pakai default per provider

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -p|--provider)
        provider="$2"
        shift
        ;;
      -m|--model)
        model="$2"
        shift
        ;;
      *)
        if [[ "$1" != -* ]] && git rev-parse --verify "$1" &>/dev/null; then
          if [[ "$1" == "master" || "$1" == "main" || "$1" == "develop" ]]; then
            base_branch="$1"
          else
            target_branch="$1"
          fi
        fi
        ;;
    esac
    shift
  done

  # Set default model per provider
  if [ -z "$model" ]; then
    case "$provider" in
      groq)   model="llama-3.3-70b-versatile" ;;
      gemini) model="gemini-2.0-flash" ;;
      *)
        echo "❌ Provider tidak dikenal: '$provider'. Pilih: groq / gemini"
        return 1
        ;;
    esac
  fi

  # Validasi API key sesuai provider
  if [ "$provider" = "groq" ] && [ -z "$GROQ_API_KEY" ]; then
    echo "❌ GROQ_API_KEY belum di-set."
    echo "Daftar gratis di https://console.groq.com lalu:"
    echo "  export GROQ_API_KEY=\"gsk_xxxxxx\""
    return 1
  fi
  if [ "$provider" = "gemini" ] && [ -z "$GEMINI_API_KEY" ]; then
    echo "❌ GEMINI_API_KEY belum di-set."
    echo "Daftar gratis di https://aistudio.google.com/apikey lalu:"
    echo "  export GEMINI_API_KEY=\"AIza_xxxxxx\""
    return 1
  fi

  # Validasi branch tidak sama
  if [ "$target_branch" = "$base_branch" ]; then
    echo "⚠️  Target branch sama dengan base branch ($base_branch)."
    return 1
  fi

  # Ambil commit log
  local commits
  commits=$(git log "$base_branch".."$target_branch" --oneline --no-decorate 2>/dev/null)

  if [ -z "$commits" ]; then
    echo "✅ Tidak ada commit baru dibanding $base_branch."
    return 0
  fi

  local commit_count=$(echo "$commits" | wc -l | tr -d ' ')

  echo ""
  echo "🌿 Target branch : $target_branch"
  echo "📌 Base branch   : $base_branch"
  echo "📋 Total commit  : $commit_count"
  echo "🤖 Provider      : $provider ($model)"
  echo ""
  echo "⏳ Generating PR..."
  echo ""

  # Buat prompt
  local prompt="You are an assistant that helps generate Pull Request (PR) titles and descriptions from a list of git commits.
Your task:
1. Analyze the provided commit list.
2. Identify the main themes of the changes (feature, fix, refactor, security, etc).
3. Generate a clean and professional Pull Request title.
4. Generate a well-structured PR description suitable for GitHub.
Rules:
- Use Conventional Commit style for the PR title (feat, fix, chore, refactor, docs, test).
- The title should summarize the most important change in the PR.
- The description must be concise but structured.
Always format the PR description with the following sections:
## Summary
A short paragraph summarizing the purpose of the PR.
## Changes
Group related changes into logical categories such as:
- Security
- Features
- Improvements
- Bug Fixes
- Refactor
- Testing
- Cleanup
Use bullet points for each change.
## Impact
Explain the benefit or impact of the changes.
## Testing
Suggest or infer reasonable testing steps if applicable.
Additional behavior:
- If commits contain typos, automatically normalize them.
- If commits overlap in theme, group them together.
- If commits are unclear, infer the most likely intention.
- Prefer clarity and readability over repeating every commit line.
When I paste a commit list, return only:
1. PR Title
2. PR Description

Here are the commits:
$commits"

  local response result error

  if [ "$provider" = "groq" ]; then
    # python3 build JSON payload, curl yang kirim (urllib diblokir Cloudflare 403)
    local json_payload
    json_payload=$(python3 -c "
import sys, json
print(json.dumps({
    'model': sys.argv[2],
    'messages': [{'role': 'user', 'content': sys.argv[1]}],
    'temperature': 0.3
}))
" "$prompt" "$model" 2>/dev/null)

    response=$(curl -s https://api.groq.com/openai/v1/chat/completions \
      -H "Authorization: Bearer $GROQ_API_KEY" \
      -H "Content-Type: application/json" \
      -d "$json_payload")

    error=$(python3 -c "
import sys, json
try:
  d = json.loads(sys.argv[1])
  print(d.get('error', {}).get('message', ''))
except: pass
" "$response" 2>/dev/null)

    result=$(python3 -c "
import sys, json
try:
  d = json.loads(sys.argv[1])
  print(d['choices'][0]['message']['content'])
except Exception as e:
  print('❌ Parse error:', e)
" "$response" 2>/dev/null)

  elif [ "$provider" = "gemini" ]; then
    # Build JSON payload untuk Gemini
    local json_payload
    json_payload=$(python3 -c "
import sys, json
print(json.dumps({
    'contents': [{'parts': [{'text': sys.argv[1]}]}],
    'generationConfig': {'temperature': 0.3}
}))
" "$prompt" 2>/dev/null)

    response=$(curl -s "https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=$GEMINI_API_KEY" \
      -H "Content-Type: application/json" \
      -d "$json_payload")

    error=$(python3 -c "
import sys, json
try:
  d = json.loads(sys.argv[1])
  print(d.get('error', {}).get('message', ''))
except: pass
" "$response" 2>/dev/null)

    result=$(python3 -c "
import sys, json
try:
  d = json.loads(sys.argv[1])
  print(d['candidates'][0]['content']['parts'][0]['text'])
except Exception as e:
  print('❌ Parse error:', e)
" "$response" 2>/dev/null)
  fi

  if [ -n "$error" ]; then
    echo "❌ API error: $error"
    return 1
  fi

  echo "$result"
  echo ""

  # Tanya apakah mau copy ke clipboard
  read "copy?📋 Copy ke clipboard? (y/N): "
  if [[ "$copy" == "y" || "$copy" == "Y" ]]; then
    echo "$result" | pbcopy
    echo "✅ Sudah di-copy ke clipboard!"
  fi
}

# Git Feature Branch Conflict Checker
# Cek apakah ada conflict antar branch tanpa benar-benar merge
#
# contoh:
# gfbconflict master kiki/feat/SP-829 kiki/feat/SP-927
# gfbconflict master kiki/fix/SP-960 kiki/feat/SP-829 kiki/feat/SP-927 kiki/feat/general-12-march
#
# output:
# ✅ kiki/feat/SP-829 → tidak ada conflict dengan master
# ⚠️  kiki/feat/SP-927 → conflict dengan kiki/feat/SP-829
gfbconflict() {
  if [ "$#" -lt 2 ]; then
    echo "❌ Gunakan: gfbconflict <base-branch> <branch1> <branch2> ..."
    echo "Contoh:"
    echo "  gfbconflict master kiki/feat/SP-829 kiki/feat/SP-927"
    return 1
  fi

  local base_branch="$1"
  shift
  local branches=("$@")
  local original_branch=$(git rev-parse --abbrev-ref HEAD)
  local temp_branch="__gfbconflict_temp__"

  # Pastikan working tree bersih
  if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "⚠️  Ada uncommitted changes. Stash atau commit dulu sebelum cek conflict."
    return 1
  fi

  echo ""
  echo "🔍 Base branch : $base_branch"
  echo "📋 Branch yang dicek: ${(j:, :)branches}"
  echo ""

  # Update base branch dulu
  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch" --quiet || return 1
  echo ""

  # Buat temp branch dari base
  git checkout -b "$temp_branch" --quiet

  local -a clean_list
  local -a conflict_list

  for branch in "${branches[@]}"; do
    # Coba merge --no-commit --no-ff
    git merge --no-commit --no-ff "$branch" --quiet 2>/dev/null
    local merge_result=$?

    if [ $merge_result -ne 0 ]; then
      # Ada conflict
      local conflict_files=$(git diff --name-only --diff-filter=U)
      conflict_list+=("$branch")
      echo "  ⚠️  $branch → CONFLICT"
      echo "$conflict_files" | while read -r f; do
        [ -n "$f" ] && echo "       └─ $f"
      done
    else
      clean_list+=("$branch")
      echo "  ✅ $branch → aman"
    fi

    # Abort merge & reset ke base agar cek berikutnya fresh
    git merge --abort 2>/dev/null
    git reset --hard "$base_branch" --quiet
  done

  # Cleanup: hapus temp branch, balik ke semula
  git checkout "$original_branch" --quiet
  git branch -D "$temp_branch" --quiet

  echo ""
  echo "══════════════════════════════════════════"
  echo "  ✅ Aman    : ${#clean_list[@]} branch"
  echo "  ⚠️  Conflict: ${#conflict_list[@]} branch"
  echo "══════════════════════════════════════════"
  echo ""
}

# Git Feature Branch Delete
# Hapus branch di local dan remote sekaligus
# Aman: tidak bisa hapus branch penting (master, main, develop, staging, production)
# Bisa pilih branch dari list, atau langsung kasih nama
#
# contoh:
# gfbdel                          → tampilkan semua branch, pilih dari list
# gfbdel kiki/feat/SP-829         → langsung hapus branch spesifik
# gfbdel -f feature               → filter list branch sebelum pilih
# gfbdel -lo kiki/feat/SP-829     → hapus local only
# gfbdel -ro kiki/feat/SP-829     → hapus remote only
gfbdel() {
  local branch_input=""
  local filter=""
  local local_only=false
  local remote_only=false

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      -lo|--local-only)  local_only=true ;;
      -ro|--remote-only) remote_only=true ;;
      *)
        if [ -z "$branch_input" ]; then
          branch_input="$1"
        fi
        ;;
    esac
    shift
  done

  # Daftar branch yang dilindungi
  local protected_pattern='^(master|main|develop|staging|production)$'

  # Jika branch langsung diberikan, skip tampil list
  if [ -n "$branch_input" ]; then
    if [[ "$branch_input" =~ $protected_pattern ]]; then
      echo "🔒 Branch '$branch_input' dilindungi dan tidak bisa dihapus."
      return 1
    fi
    _gfbdel_execute "$branch_input" "$local_only" "$remote_only"
    return $?
  fi

  # Tidak ada input → tampilkan list branch untuk dipilih
  echo "🔄 Fetching origin..."
  git fetch --quiet 2>/dev/null

  local local_branches
  local_branches=$(git branch \
    | sed 's/^[* ]*//' \
    | grep -vE "$protected_pattern")

  if [ -n "$filter" ]; then
    local_branches=$(echo "$local_branches" | grep "$filter")
  fi

  if [ -z "$local_branches" ]; then
    echo "⚠️  Tidak ada branch yang bisa dihapus."
    return 0
  fi

  echo ""
  echo "🗑 Branch yang tersedia untuk dihapus:"
  local i=1
  declare -a branch_list
  while read -r branch; do
    [ -z "$branch" ] && continue
    echo "  [$i] $branch"
    branch_list[$i]="$branch"
    ((i++))
  done <<< "$local_branches"

  echo ""
  read "selection?Pilih nomor branch yang ingin dihapus: "

  if [ -z "$selection" ]; then
    echo "❌ Tidak ada yang dipilih. Dibatalkan."
    return 0
  fi

  local selected_branch="${branch_list[$selection]}"

  if [ -z "$selected_branch" ]; then
    echo "❌ Nomor tidak valid."
    return 1
  fi

  _gfbdel_execute "$selected_branch" "$local_only" "$remote_only"
}

# Helper internal untuk gfbdel: eksekusi hapus branch local dan/atau remote
_gfbdel_execute() {
  local branch="$1"
  local local_only="$2"
  local remote_only="$3"
  local current_branch=$(git rev-parse --abbrev-ref HEAD)

  # Cek apakah sedang di branch yang mau dihapus
  if [ "$current_branch" = "$branch" ]; then
    echo "⚠️  Kamu sedang berada di branch '$branch'."
    echo "Pindah dulu ke branch lain sebelum menghapus."
    return 1
  fi

  # Cek eksistensi di local dan remote
  local has_local=false
  local has_remote=false
  git show-ref --verify --quiet "refs/heads/$branch"          && has_local=true
  git show-ref --verify --quiet "refs/remotes/origin/$branch" && has_remote=true

  if ! $has_local && ! $has_remote; then
    echo "❌ Branch '$branch' tidak ditemukan (local maupun remote)."
    return 1
  fi

  echo ""
  echo "🗑 Branch yang akan dihapus: $branch"
  $has_local  && ! $remote_only && echo "  └─ local  : ✓"
  $has_remote && ! $local_only  && echo "  └─ remote : ✓"
  echo ""

  read "confirm?Lanjutkan hapus? (y/N): "
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "❌ Dibatalkan."
    return 0
  fi

  # Hapus local
  if $has_local && ! $remote_only; then
    echo "➡️  Hapus local: $branch"
    git branch -d "$branch" 2>/dev/null || git branch -D "$branch"
  fi

  # Hapus remote
  if $has_remote && ! $local_only; then
    echo "➡️  Hapus remote: origin/$branch"
    git push origin --delete "$branch"
  fi

  echo "✅ Branch '$branch' berhasil dihapus."
}

# Git Feature Branch Range
# Menampilkan list commit dan file yang berubah di antara dua commit hash
# Mendukung short hash maupun full hash
#
# contoh:
# gfbrange abc1234 def5678
# gfbrange abc1234 def5678 -f src/services
gfbrange() {
  local hash1=""
  local hash2=""
  local filter=""

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        if [ -z "$hash1" ]; then
          hash1="$1"
        elif [ -z "$hash2" ]; then
          hash2="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi input
  if [ -z "$hash1" ] || [ -z "$hash2" ]; then
    echo "❌ Gunakan: gfbrange <hash1> <hash2> [-f keyword]"
    echo "Contoh:"
    echo "  gfbrange abc1234 def5678"
    echo "  gfbrange abc1234 def5678 -f src/services"
    return 1
  fi

  # Validasi kedua commit hash exist
  if ! git cat-file -e "$hash1^{commit}" 2>/dev/null; then
    echo "❌ Commit '$hash1' tidak ditemukan di repo ini."
    return 1
  fi
  if ! git cat-file -e "$hash2^{commit}" 2>/dev/null; then
    echo "❌ Commit '$hash2' tidak ditemukan di repo ini."
    return 1
  fi

  local short1=$(git rev-parse --short "$hash1")
  local short2=$(git rev-parse --short "$hash2")

  # Ambil list commit antara hash1..hash2
  local commits
  commits=$(git log "$hash1".."$hash2" --oneline --no-decorate 2>/dev/null)

  echo ""
  echo "🔗 Range   : $short1 → $short2"

  if [ -z "$commits" ]; then
    # Coba balik urutan, mungkin hash1 lebih baru dari hash2
    commits=$(git log "$hash2".."$hash1" --oneline --no-decorate 2>/dev/null)
    if [ -n "$commits" ]; then
      echo "⚠️  Urutan dibalik: $short2 → $short1"
      # Tukar supaya diff file juga konsisten
      local tmp="$hash1"; hash1="$hash2"; hash2="$tmp"
      short1=$(git rev-parse --short "$hash1")
      short2=$(git rev-parse --short "$hash2")
    else
      echo "✅ Tidak ada commit di antara kedua hash tersebut."
      return 0
    fi
  fi

  local commit_count=$(echo "$commits" | wc -l | tr -d ' ')

  # ── Tampilkan commit list ──────────────────────────────────────
  echo ""
  echo "📋 Commits ($commit_count):"
  local i=1
  while read -r line; do
    echo "  [$i] $line"
    ((i++))
  done <<< "$commits"

  # ── Tampilkan file yang berubah ────────────────────────────────
  # --diff-filter: M=Modified A=Added D=Deleted R=Renamed C=Copied
  local changed_files
  changed_files=$(git diff --name-status "$hash1" "$hash2" 2>/dev/null)

  if [ -n "$filter" ]; then
    changed_files=$(echo "$changed_files" | grep "$filter")
  fi

  if [ -z "$changed_files" ]; then
    echo ""
    echo "📂 Tidak ada file yang berubah."
    return 0
  fi

  # Hitung per status
  local count_m=$(echo "$changed_files" | grep -c '^M' || true)
  local count_a=$(echo "$changed_files" | grep -c '^A' || true)
  local count_d=$(echo "$changed_files" | grep -c '^D' || true)
  local count_r=$(echo "$changed_files" | grep -c '^R' || true)
  local count_c=$(echo "$changed_files" | grep -c '^C' || true)
  local total_files=$(echo "$changed_files" | grep -c '.' || true)

  echo ""
  echo "📂 Files changed ($total_files):"

  # fstatus menggantikan status (reserved variable di zsh)
  while IFS=$'\t' read -r fstatus filepath rest; do
    [ -z "$fstatus" ] && continue
    case "${fstatus:0:1}" in
      M) echo "  \033[33m[M]\033[0m  $filepath" ;;  # Modified  → kuning
      A) echo "  \033[32m[A]\033[0m  $filepath" ;;  # Added     → hijau
      D) echo "  \033[31m[D]\033[0m  $filepath" ;;  # Deleted   → merah
      R) echo "  \033[34m[R]\033[0m  $filepath → $rest" ;;  # Renamed → biru
      C) echo "  \033[36m[C]\033[0m  $filepath → $rest" ;;  # Copied  → cyan
      *) echo "  [?]  $filepath" ;;
    esac
  done <<< "$changed_files"

  # Summary
  echo ""
  echo "──────────────────────────────────────────────────────"
  printf "  Total: %-4s" "$total_files"
  [ "$count_m" -gt 0 ] && printf "  \033[33mM:%-3s\033[0m" "$count_m"
  [ "$count_a" -gt 0 ] && printf "  \033[32mA:%-3s\033[0m" "$count_a"
  [ "$count_d" -gt 0 ] && printf "  \033[31mD:%-3s\033[0m" "$count_d"
  [ "$count_r" -gt 0 ] && printf "  \033[34mR:%-3s\033[0m" "$count_r"
  [ "$count_c" -gt 0 ] && printf "  \033[36mC:%-3s\033[0m" "$count_c"
  echo ""
  echo "──────────────────────────────────────────────────────"
  echo ""
}

# Git Feature Branch Compare
# Membandingkan dua branch secara menyeluruh:
# - Common ancestor (titik diverge)
# - Ahead/behind count di kedua arah
# - Commit yang ada di branch A tapi tidak di branch B (dan sebaliknya)
# - File yang berbeda antara kedua branch
#
# contoh:
# gfbcompare master feature/login
# gfbcompare master feature/login -f src/services
# gfbcompare develop kiki/feat/SP-829
gfbcompare() {
  local branch_a=""
  local branch_b=""
  local filter=""

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        if [ -z "$branch_a" ]; then
          branch_a="$1"
        elif [ -z "$branch_b" ]; then
          branch_b="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi input
  if [ -z "$branch_a" ] || [ -z "$branch_b" ]; then
    echo "❌ Gunakan: gfbcompare <branch-a> <branch-b> [-f keyword]"
    echo "Contoh:"
    echo "  gfbcompare master feature/login"
    echo "  gfbcompare develop kiki/feat/SP-829 -f src/services"
    return 1
  fi

  # Validasi kedua branch exist
  if ! git rev-parse --verify "$branch_a" &>/dev/null; then
    echo "❌ Branch '$branch_a' tidak ditemukan."
    return 1
  fi
  if ! git rev-parse --verify "$branch_b" &>/dev/null; then
    echo "❌ Branch '$branch_b' tidak ditemukan."
    return 1
  fi

  # ── Header ────────────────────────────────────────────────────
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║               🔀 Branch Comparison                          ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  echo "  🅐  $branch_a"
  echo "  🅑  $branch_b"
  echo ""

  # ── Common ancestor ───────────────────────────────────────────
  local merge_base
  merge_base=$(git merge-base "$branch_a" "$branch_b" 2>/dev/null)

  if [ -n "$merge_base" ]; then
    local base_short=$(git rev-parse --short "$merge_base")
    local base_msg=$(git log -1 --pretty=format:"%s" "$merge_base")
    local base_date=$(git log -1 --pretty=format:"%cd" --date=format:"%Y-%m-%d" "$merge_base")
    echo "──────────────────────────────────────────────────────"
    echo "  🌱 Common Ancestor"
    echo "──────────────────────────────────────────────────────"
    echo "  Hash : $base_short"
    echo "  Pesan: $base_msg"
    echo "  Tanggal: $base_date"
    echo ""
  fi

  # ── Ahead / Behind ────────────────────────────────────────────
  local ahead_a=$(git rev-list --count "$branch_b".."$branch_a" 2>/dev/null)
  local ahead_b=$(git rev-list --count "$branch_a".."$branch_b" 2>/dev/null)

  echo "──────────────────────────────────────────────────────"
  echo "  📊 Ahead / Behind"
  echo "──────────────────────────────────────────────────────"
  echo "  🅐  $branch_a : \033[32m↑ $ahead_a commit\033[0m di depan 🅑"
  echo "  🅑  $branch_b : \033[33m↑ $ahead_b commit\033[0m di depan 🅐"
  echo ""

  # ── Commit eksklusif di A (tidak ada di B) ────────────────────
  local commits_only_a
  commits_only_a=$(git log "$branch_b".."$branch_a" --oneline --no-decorate 2>/dev/null)

  echo "──────────────────────────────────────────────────────"
  echo "  📋 Commit hanya di 🅐  $branch_a  ($ahead_a)"
  echo "──────────────────────────────────────────────────────"
  if [ -z "$commits_only_a" ]; then
    echo "  (tidak ada)"
  else
    local i=1
    while read -r line; do
      echo "  [$i] $line"
      ((i++))
    done <<< "$commits_only_a"
  fi
  echo ""

  # ── Commit eksklusif di B (tidak ada di A) ────────────────────
  local commits_only_b
  commits_only_b=$(git log "$branch_a".."$branch_b" --oneline --no-decorate 2>/dev/null)

  echo "──────────────────────────────────────────────────────"
  echo "  📋 Commit hanya di 🅑  $branch_b  ($ahead_b)"
  echo "──────────────────────────────────────────────────────"
  if [ -z "$commits_only_b" ]; then
    echo "  (tidak ada)"
  else
    local i=1
    while read -r line; do
      echo "  [$i] $line"
      ((i++))
    done <<< "$commits_only_b"
  fi
  echo ""

  # ── File yang berbeda antara kedua branch ─────────────────────
  local changed_files
  changed_files=$(git diff --name-status "$branch_a".."$branch_b" 2>/dev/null)

  if [ -n "$filter" ]; then
    changed_files=$(echo "$changed_files" | grep "$filter")
  fi

  echo "──────────────────────────────────────────────────────"
  echo "  📂 Files changed 🅐 → 🅑"
  echo "──────────────────────────────────────────────────────"

  if [ -z "$changed_files" ]; then
    echo "  (tidak ada perbedaan file)"
    echo ""
    return 0
  fi

  # Hitung per status
  local count_m=$(echo "$changed_files" | grep -c '^M' || true)
  local count_a=$(echo "$changed_files" | grep -c '^A' || true)
  local count_d=$(echo "$changed_files" | grep -c '^D' || true)
  local count_r=$(echo "$changed_files" | grep -c '^R' || true)
  local count_c=$(echo "$changed_files" | grep -c '^C' || true)
  local total_files=$(echo "$changed_files" | grep -c '.' || true)

  # fstatus menggantikan status (reserved variable di zsh)
  while IFS=$'\t' read -r fstatus filepath rest; do
    [ -z "$fstatus" ] && continue
    case "${fstatus:0:1}" in
      M) echo "  \033[33m[M]\033[0m  $filepath" ;;  # Modified  → kuning
      A) echo "  \033[32m[A]\033[0m  $filepath" ;;  # Added     → hijau
      D) echo "  \033[31m[D]\033[0m  $filepath" ;;  # Deleted   → merah
      R) echo "  \033[34m[R]\033[0m  $filepath → $rest" ;;  # Renamed → biru
      C) echo "  \033[36m[C]\033[0m  $filepath → $rest" ;;  # Copied  → cyan
      *) echo "  [?]  $filepath" ;;
    esac
  done <<< "$changed_files"

  # ── Summary ───────────────────────────────────────────────────
  echo ""
  echo "══════════════════════════════════════════════════════"
  printf "  Total file: %-4s" "$total_files"
  [ "$count_m" -gt 0 ] && printf "  \033[33mM:%-3s\033[0m" "$count_m"
  [ "$count_a" -gt 0 ] && printf "  \033[32mA:%-3s\033[0m" "$count_a"
  [ "$count_d" -gt 0 ] && printf "  \033[31mD:%-3s\033[0m" "$count_d"
  [ "$count_r" -gt 0 ] && printf "  \033[34mR:%-3s\033[0m" "$count_r"
  [ "$count_c" -gt 0 ] && printf "  \033[36mC:%-3s\033[0m" "$count_c"
  echo ""
  echo "══════════════════════════════════════════════════════"
  echo ""
}

