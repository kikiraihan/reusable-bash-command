  echo "  Contoh  :"
  echo "    gfb master fitur-login          → buat branch lokal"
  echo "    gfb -p develop fitur-payment    → buat + push ke origin"
  echo ""

  echo "──────────────────────────────────────────────────────────────"
  echo "  gfbclean — Hapus branch yang sudah merged"
