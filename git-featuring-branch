    echo "❓ Gunakan: gfbmain --help"
    return 1
  fi

  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║           🌿 GFB — Git Feature Branch Toolkit               ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""

  echo "──────────────────────────────────────────────────────────────"
  echo "  gfb — Buat branch baru dari base branch"
  echo "──────────────────────────────────────────────────────────────"
