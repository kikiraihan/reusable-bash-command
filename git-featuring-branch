# command untuk buat branch baru dari master, langsung push, dan set upstream
# Fungsi GFB (Git Feature Branch) dengan opsi push
# contoh penggunaan:
# gfb master fitur-keren
# gfb -p master fitur-keren
# gfb -p develop fitur-keren
gfb() {
  local push_to_origin=false
  local base_branch=""
  local branch_name=""

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -p|--push) push_to_origin=true ;;
      *)
        if [ -z "$base_branch" ]; then
          base_branch="$1"
        elif [ -z "$branch_name" ]; then
          branch_name="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi input
  if [ -z "$base_branch" ] || [ -z "$branch_name" ]; then
    echo "❌ Gunakan: gfb [-p] <base-branch> <nama-branch-baru>"
    echo "Contoh:"
    echo "  gfb master fitur-login"
    echo "  gfb develop fitur-payment"
    echo "  gfb -p develop fitur-api"
    return 1
  fi

  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch"

  if [ $? -ne 0 ]; then
    echo "⚠️ Gagal update $base_branch. Cek apakah ada uncommitted changes."
    return 1
  fi

  echo "🌿 Membuat branch: $branch_name dari $base_branch"
  git checkout -b "$branch_name"

  if [ "$push_to_origin" = true ]; then
    echo "🚀 Push dan set upstream..."
    git push -u origin "$branch_name"
    echo "✅ Berhasil dibuat dan di-push!"
  else
    echo "📍 Branch dibuat secara lokal."
    echo "Gunakan: git push -u origin $branch_name"
  fi
}

# Git Feature Branch Cleaner
# Menghapus branch yang sudah merged ke base branch
# Aman: ignore branch penting + bisa pilih branch
#
# contoh:
# gfbclean master
#
# contoh dengan filter:
# gfbclean master -f kiki
#
# contoh input pilihan:
# 1 3 5
# 1,3,5
# all
#
# output:
# 🗑 Branch yang bisa dihapus:
# [1] feature/login
# [2] feature/payment
# [3] bugfix/token
# Pilih nomor branch (contoh: 1 3 atau 1,3) atau ketik 'all' untuk semua:
gfbclean() {
  local base_branch=""
  local filter=""

  # parse arg
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        base_branch="$1"
        ;;
    esac
    shift
  done

  if [ -z "$base_branch" ]; then
    echo "❌ Gunakan: gfbclean <base-branch> [-f keyword]"
    return 1
  fi

  local original_branch=$(git rev-parse --abbrev-ref HEAD)

  # Tangkap Ctrl+C: balik ke branch semula sebelum exit
  trap "echo ''; echo '🔙 Kembali ke branch: $original_branch'; git checkout \"$original_branch\"; trap - INT; return 1" INT

  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch" || { trap - INT; return 1; }

  echo "🔍 Mencari branch yang sudah merged ke $base_branch..."
  local branches
  branches=$(git branch --merged "$base_branch" \
    | sed 's/^[* ]*//' \
    | grep -vE '^(master|main|develop|staging|production)$')

  if [ -n "$filter" ]; then
    branches=$(echo "$branches" | grep "$filter")
  fi

  if [ -z "$branches" ]; then
    echo "✅ Tidak ada branch yang cocok untuk dibersihkan."
    trap - INT
    return 0
  fi

  echo ""
  echo "🗑 Branch yang bisa dihapus:"
  local i=1
  declare -a branch_list
  while read -r branch; do
    echo "[$i] $branch"
    branch_list[$i]="$branch"
    ((i++))
  done <<< "$branches"

  echo ""
  read "selection?Pilih nomor branch (contoh: 1,3 atau 1,3,5) atau ketik 'all' untuk semua: "

  # ubah koma jadi spasi lalu split ke array (zsh-safe)
  local selection_clean=$(echo "$selection" | tr ',' ' ')
  local -a nums
  read -A nums <<< "$selection_clean"

  local -a selected_branches
  if [[ "$selection" == "all" ]]; then
    selected_branches=("${branch_list[@]}")
  else
    for num in "${nums[@]}"; do
      [[ "$num" =~ ^[0-9]+$ ]] && selected_branches+=("${branch_list[$num]}")
    done
  fi

  echo ""
  echo "Branch yang akan dihapus:"
  for b in "${selected_branches[@]}"; do
    [ -z "$b" ] && continue
    echo "- $b"
  done

  echo ""
  read "confirm?Lanjutkan hapus branch di atas? (y/N): "
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "❌ Dibatalkan."
    trap - INT
    return 0
  fi

  for branch in "${selected_branches[@]}"; do
    [ -z "$branch" ] && continue
    echo "➡️ Hapus local: $branch"
    git branch -d "$branch"
    echo "➡️ Hapus origin: $branch"
    git push origin --delete "$branch"
  done

  echo "✅ Selesai membersihkan branch."
  echo ""
  echo "🔙 Kembali ke branch: $original_branch"
  git checkout "$original_branch"
  trap - INT  # reset trap setelah selesai normal
}

# Git Feature Branch Checker
# Menampilkan branch yang BELUM merged ke base branch
# Aman: ignore branch penting
#
# contoh:
# gfbcheck master
#
# contoh dengan filter:
# gfbcheck master -f kiki
#
# output:
# 🌿 Branch yang belum merged ke master:
# [1] feature/login
# [2] feature/payment
# [3] bugfix/token
gfbcheck() {
  local base_branch=""
  local filter=""

  # parse arg
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        base_branch="$1"
        ;;
    esac
    shift
  done

  if [ -z "$base_branch" ]; then
    echo "❌ Gunakan: gfbcheck <base-branch> [-f keyword]"
    return 1
  fi

  local original_branch=$(git rev-parse --abbrev-ref HEAD)

  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch" || return 1

  echo "🔍 Mencari branch yang belum merged ke $base_branch..."
  local branches
  branches=$(git branch --no-merged "$base_branch" \
    | sed 's/^[* ]*//' \
    | grep -vE '^(master|main|develop|staging|production)$')

  if [ -n "$filter" ]; then
    branches=$(echo "$branches" | grep "$filter")
  fi

  if [ -z "$branches" ]; then
    echo "✅ Semua branch sudah merged ke $base_branch."
    return 0
  fi

  echo ""
  echo "🌿 Branch yang belum merged ke $base_branch:"
  local i=1
  while read -r branch; do
    echo "[$i] $branch"
    ((i++))
  done <<< "$branches"

  echo ""
  echo "Total: $((i-1)) branch"
  echo ""
  echo "🔙 Kembali ke branch: $original_branch"
  git checkout "$original_branch"
}

# gfblog master                        → compare master vs current branch
# gfblog master feature/login          → compare master vs feature/login
gfblog() {
  local base_branch="${1:-master}"
  local target_branch="${2:-$(git rev-parse --abbrev-ref HEAD)}"

  if [ "$target_branch" = "$base_branch" ]; then
    echo "⚠️  Target branch sama dengan base branch ($base_branch)."
    return 1
  fi

  local commits=$(git log "$base_branch".."$target_branch" --oneline --no-decorate)

  if [ -z "$commits" ]; then
    echo "✅ Tidak ada commit baru dibanding $base_branch."
    return 0
  fi

  echo ""
  echo "🌿 Target branch : $target_branch"
  echo "📌 Base branch   : $base_branch"
  echo ""
  echo "📋 Commit yang belum ada di $base_branch:"
  echo "$commits" | while read -r line; do
    echo "  - $line"
  done
  echo ""
  echo "Total: $(echo "$commits" | wc -l | tr -d ' ') commit"
}

# Git Feature Branch Find Commit
# Mencari commit hash ada di branch mana saja
# Opsional: -r untuk cek remote branches juga
#
# contoh:
# gfbfind 56c97cde945a078ee1525a20acc9ea0927c5580b
# gfbfind 56c97cde -r
# gfbfind 56c97cde -f feature
gfbfind() {
  local commit_hash=""
  local include_remote=false
  local filter=""

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -r|--remote) include_remote=true ;;
      -f|--filter)
        filter="$2"
        shift
        ;;
      *)
        if [ -z "$commit_hash" ]; then
          commit_hash="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi input
  if [ -z "$commit_hash" ]; then
    echo "❌ Gunakan: gfbfind <commit-hash> [-r] [-f keyword]"
    echo "Contoh:"
    echo "  gfbfind 56c97cde"
    echo "  gfbfind 56c97cde945a078ee1525a20acc9ea0927c5580b -r"
    echo "  gfbfind 56c97cde -f feature"
    return 1
  fi

  # Validasi commit hash exist
  if ! git cat-file -e "$commit_hash^{commit}" 2>/dev/null; then
    echo "❌ Commit '$commit_hash' tidak ditemukan di repo ini."
    return 1
  fi

  local short_hash=$(git rev-parse --short "$commit_hash")
  local commit_msg=$(git log -1 --pretty=format:"%s" "$commit_hash")

  echo ""
  echo "🔍 Mencari commit: $short_hash"
  echo "📝 Pesan        : $commit_msg"
  echo ""

  # Tentukan flag: local saja atau termasuk remote
  local branch_flag=""
  if [ "$include_remote" = true ]; then
    echo "🌐 Mode: local + remote branches"
    branch_flag="-a"  # all: local + remote
  else
    echo "💻 Mode: local branches saja (gunakan -r untuk remote)"
    branch_flag=""    # default: local only
  fi
  echo ""

  # Cari branch yang mengandung commit ini
  local found_branches
  found_branches=$(git branch $branch_flag --contains "$commit_hash" \
    | sed 's/^[* ]*//' \
    | sed 's|^remotes/||')  # rapikan prefix remotes/

  if [ -n "$filter" ]; then
    found_branches=$(echo "$found_branches" | grep "$filter")
  fi

  if [ -z "$found_branches" ]; then
    echo "⚠️  Commit tidak ditemukan di branch manapun."
    return 0
  fi

  local count=$(echo "$found_branches" | wc -l | tr -d ' ')

  echo "✅ Ditemukan di $count branch:"
  echo ""
  local i=1
  while read -r branch; do
    [ -z "$branch" ] && continue
    echo "  [$i] $branch"
    ((i++))
  done <<< "$found_branches"
  echo ""
}

# Git Feature Branch List
# Menampilkan list branch yang mengandung keyword tertentu
# Opsional: -r untuk include remote branches juga
#
# contoh:
# gfbls kiki
# gfbls kiki -r
gfbls() {
  local keyword=""
  local include_remote=false

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -r|--remote) include_remote=true ;;
      *)
        if [ -z "$keyword" ]; then
          keyword="$1"
        fi
        ;;
    esac
    shift
  done

  # Jika tidak ada keyword, tampil semua branch
  # keyword kosong = grep akan match semua baris

  # Ambil local branches
  local local_branches
  local_branches=$(git branch \
    | sed 's/^[* ]*//' \
    | grep "$keyword")

  # Ambil remote branches (selalu, untuk keperluan cek & mode -r)
  local remote_branches
  remote_branches=$(git branch -r \
    | sed 's/^[* ]*//' \
    | sed 's/^origin\///' \
    | grep -v 'HEAD' \
    | grep "$keyword")

  # Tentukan sumber data sesuai mode
  local all_branches
  if [ "$include_remote" = true ]; then
    all_branches=$(printf "%s\n%s\n" "$local_branches" "$remote_branches" \
      | grep -v '^$' | sort -u)
  else
    all_branches="$local_branches"
  fi

  if [ -z "$all_branches" ]; then
    echo "⚠️  Tidak ada branch yang mengandung keyword: '$keyword'"
    return 0
  fi

  local keyword_label="${keyword:-semua}"
  local count=$(echo "$all_branches" | grep -c .)
  local mode="local"
  [ "$include_remote" = true ] && mode="local + remote"

  echo ""
  echo "🔍 Keyword  : $keyword_label"
  echo "🌐 Mode     : $mode"
  echo "📋 Ditemukan: $count branch"
  echo ""

  # Fetch dulu supaya info remote fresh
  echo "🔄 Fetching origin..."
  git fetch --quiet 2>/dev/null

  local i=1
  while read -r branch; do
    [ -z "$branch" ] && continue
    local has_local=false
    local has_remote=false
    echo "$local_branches"  | grep -qx "$branch" && has_local=true
    echo "$remote_branches" | grep -qx "$branch" && has_remote=true

    if $has_local && $has_remote; then
      # Hitung ahead/behind
      local ahead=$(git rev-list --count "origin/$branch".."$branch" 2>/dev/null)
      local behind=$(git rev-list --count "$branch".."origin/$branch" 2>/dev/null)
      local sync_info=""
      [ "$ahead" -gt 0 ] 2>/dev/null  && sync_info+=" ↑${ahead}"
      [ "$behind" -gt 0 ] 2>/dev/null && sync_info+=" ↓${behind}"
      [ -z "$sync_info" ] && sync_info=" ✓"
      echo "  [$i] $branch$sync_info"
      echo "       └─ origin/$branch"
    elif $has_local; then
      echo "  [$i] $branch  (local only — belum pernah push)"
    else
      echo "  [$i] origin/$branch  (remote only — belum di-fetch lokal)"
    fi
    ((i++))
  done <<< "$all_branches"
  echo ""
  echo "  ↑ = commit lokal belum di-push   ↓ = commit remote belum di-pull   ✓ = sinkron"
  echo ""
}

# Git Feature Branch PR Generator
# Generate PR title & description dari commit log menggunakan Groq API (LLM gratis)
# Requires: GROQ_API_KEY di environment
#
# contoh:
# gfbpr master                        → generate PR dari master vs current branch
# gfbpr master kiki/feat/SP-829       → generate PR dari master vs branch tertentu
# gfbpr master -m llama3-8b-8192      → pilih model manual

# Model Kecepatan Kualitas
# llama-3.3-70b-versatile Sedang⭐⭐⭐⭐⭐ (default kita)
# llama3-8b-8192 Sangat cepat⭐⭐⭐
# gemma2-9b-it Cepat⭐⭐⭐
# qwen-qwq-32b Lambat⭐⭐⭐⭐⭐ (reasoning)
# mistral-saba-24b Sedang⭐⭐⭐⭐

gfbpr() {
  local base_branch="master"
  local target_branch=$(git rev-parse --abbrev-ref HEAD)
  local model="llama-3.3-70b-versatile"  # default model gratis groq

  # Parsing argumen
  while [[ "$#" -gt 0 ]]; do
    case $1 in
      -m|--model)
        model="$2"
        shift
        ;;
      *)
        if [ "$1" = "$base_branch" ] || [ -z "$base_branch" ]; then
          base_branch="$1"
        else
          target_branch="$1"
        fi
        ;;
    esac
    shift
  done

  # Validasi API key
  if [ -z "$GROQ_API_KEY" ]; then
    echo "❌ GROQ_API_KEY belum di-set."
    echo "Daftar gratis di https://console.groq.com lalu:"
    echo "  export GROQ_API_KEY=\"gsk_xxxxxx\""
    return 1
  fi

  # Validasi branch tidak sama
  if [ "$target_branch" = "$base_branch" ]; then
    echo "⚠️  Target branch sama dengan base branch ($base_branch)."
    return 1
  fi

  # Ambil commit log
  local commits
  commits=$(git log "$base_branch".."$target_branch" --oneline --no-decorate 2>/dev/null)

  if [ -z "$commits" ]; then
    echo "✅ Tidak ada commit baru dibanding $base_branch."
    return 0
  fi

  local commit_count=$(echo "$commits" | wc -l | tr -d ' ')

  echo ""
  echo "🌿 Target branch : $target_branch"
  echo "📌 Base branch   : $base_branch"
  echo "📋 Total commit  : $commit_count"
  echo "🤖 Model         : $model"
  echo ""
  echo "⏳ Generating PR dengan Groq..."
  echo ""

  # Buat prompt
  local prompt="You are an assistant that helps generate Pull Request (PR) titles and descriptions from a list of git commits.
Your task:
1. Analyze the provided commit list.
2. Identify the main themes of the changes (feature, fix, refactor, security, etc).
3. Generate a clean and professional Pull Request title.
4. Generate a well-structured PR description suitable for GitHub.
Rules:
- Use Conventional Commit style for the PR title (feat, fix, chore, refactor, docs, test).
- The title should summarize the most important change in the PR.
- The description must be concise but structured.
Always format the PR description with the following sections:
## Summary
A short paragraph summarizing the purpose of the PR.
## Changes
Group related changes into logical categories such as:
- Security
- Features
- Improvements
- Bug Fixes
- Refactor
- Testing
- Cleanup
Use bullet points for each change.
## Impact
Explain the benefit or impact of the changes.
## Testing
Suggest or infer reasonable testing steps if applicable.
Additional behavior:
- If commits contain typos, automatically normalize them.
- If commits overlap in theme, group them together.
- If commits are unclear, infer the most likely intention.
- Prefer clarity and readability over repeating every commit line.
When I paste a commit list, return only:
1. PR Title
2. PR Description

Here are the commits:
$commits"

  # Kirim ke Groq API — python3 build JSON, curl yang kirim
  # (urllib diblokir Cloudflare dengan 403, curl lolos)
  local json_payload
  json_payload=$(python3 -c "
import sys, json
prompt = sys.argv[1]
model  = sys.argv[2]
print(json.dumps({
    'model': model,
    'messages': [{'role': 'user', 'content': prompt}],
    'temperature': 0.3
}))
" "$prompt" "$model" 2>/dev/null)

  local response
  response=$(curl -s https://api.groq.com/openai/v1/chat/completions \
    -H "Authorization: Bearer $GROQ_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$json_payload")

  # Cek error dari API
  local error
  error=$(python3 -c "
import sys, json
try:
  d = json.loads(sys.argv[1])
  print(d.get('error', {}).get('message', ''))
except: pass
" "$response" 2>/dev/null)

  if [ -n "$error" ]; then
    echo "❌ Groq API error: $error"
    return 1
  fi

  # Ekstrak hasil
  local result
  result=$(python3 -c "
import sys, json
try:
  d = json.loads(sys.argv[1])
  print(d['choices'][0]['message']['content'])
except Exception as e:
  print('❌ Parse error:', e)
" "$response" 2>/dev/null)

  echo "$result"
  echo ""

  # Tanya apakah mau copy ke clipboard
  read "copy?📋 Copy ke clipboard? (y/N): "
  if [[ "$copy" == "y" || "$copy" == "Y" ]]; then
    echo "$result" | pbcopy
    echo "✅ Sudah di-copy ke clipboard!"
  fi
}

# Git Feature Branch Conflict Checker
# Cek apakah ada conflict antar branch tanpa benar-benar merge
#
# contoh:
# gfbconflict master kiki/feat/SP-829 kiki/feat/SP-927
# gfbconflict master kiki/fix/SP-960 kiki/feat/SP-829 kiki/feat/SP-927 kiki/feat/general-12-march
#
# output:
# ✅ kiki/feat/SP-829 → tidak ada conflict dengan master
# ⚠️  kiki/feat/SP-927 → conflict dengan kiki/feat/SP-829
gfbconflict() {
  if [ "$#" -lt 2 ]; then
    echo "❌ Gunakan: gfbconflict <base-branch> <branch1> <branch2> ..."
    echo "Contoh:"
    echo "  gfbconflict master kiki/feat/SP-829 kiki/feat/SP-927"
    return 1
  fi

  local base_branch="$1"
  shift
  local branches=("$@")
  local original_branch=$(git rev-parse --abbrev-ref HEAD)
  local temp_branch="__gfbconflict_temp__"
  local has_conflict=false

  # Pastikan working tree bersih
  if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "⚠️  Ada uncommitted changes. Stash atau commit dulu sebelum cek conflict."
    return 1
  fi

  echo ""
  echo "🔍 Base branch : $base_branch"
  echo "📋 Branch yang dicek: ${(j:, :)branches}"
  echo ""

  # Update base branch dulu
  echo "🔄 Pulling newest $base_branch..."
  git checkout "$base_branch" && git pull origin "$base_branch" --quiet || return 1
  echo ""

  # Buat temp branch dari base
  git checkout -b "$temp_branch" --quiet

  local -a clean_list
  local -a conflict_list

  for branch in "${branches[@]}"; do
    # Coba merge --no-commit --no-ff
    git merge --no-commit --no-ff "$branch" --quiet 2>/dev/null
    local merge_result=$?

    if [ $merge_result -ne 0 ]; then
      # Ada conflict
      local conflict_files=$(git diff --name-only --diff-filter=U)
      conflict_list+=("$branch")
      echo "  ⚠️  $branch → CONFLICT"
      echo "$conflict_files" | while read -r f; do
        [ -n "$f" ] && echo "       └─ $f"
      done
    else
      clean_list+=("$branch")
      echo "  ✅ $branch → aman"
    fi

    # Abort merge & reset ke base agar cek berikutnya fresh
    git merge --abort 2>/dev/null
    git reset --hard "$base_branch" --quiet
  done

  # Cleanup: hapus temp branch, balik ke semula
  git checkout "$original_branch" --quiet
  git branch -D "$temp_branch" --quiet

  echo ""
  echo "══════════════════════════════════════════"
  echo "  ✅ Aman    : ${#clean_list[@]} branch"
  echo "  ⚠️  Conflict: ${#conflict_list[@]} branch"
  echo "══════════════════════════════════════════"
  echo ""
}

# GFB Main — menampilkan daftar semua perintah GFB beserta usage-nya
